@using System.ComponentModel.DataAnnotations
@inherits GamePlayBase
@inject IMessageParser MessageParser

<Paragraph>
    Players (min. @GameEngine.MinPlayerCount, max. @GameEngine.MaxPlayerCount):
    <AppUsersBadge Users="@OrderedUsers" />
</Paragraph>

<Container Padding="Padding.Is0">
    @if (IsOwner) {
        <Form @onsubmit="_ => Edit()" Margin="Margin.Is0">
            <Addons Margin="Margin.Is3.OnY">
                <Addon AddonType="AddonType.Start">
                    <AddonLabel>
                        <Blazorise.Icon Name="FontAwesomeIcons.Comment" />
                    </AddonLabel>
                </Addon>
                <input @bind="@Intro.Value" @bind:event="onchange"
                        class="form-control" placeholder="Introduction or game title?"/>
                <Addon AddonType="AddonType.End">
                    <Button Type="@ButtonType.Submit" Color="Color.Primary">
                        <Blazorise.Icon Name="FontAwesomeIcons.Check"/>
                    </Button>
                </Addon>
            </Addons>
            @if (Game.RoundCount.HasValue) {
                <Addons Margin="Margin.Is3.OnY">
                    <Addon AddonType="AddonType.Start">
                        <AddonLabel>Rounds:</AddonLabel>
                    </Addon>
                    <input @bind="@RoundCount.Value" @bind:event="onchange" class="form-control" />
                    <Addon AddonType="AddonType.End">
                        <Button Type="@ButtonType.Submit" Color="Color.Primary" Disabled="@(!RoundCount.IsValid)">
                            <Blazorise.Icon Name="FontAwesomeIcons.Check"/>
                        </Button>
                    </Addon>
                </Addons>
            }
        </Form>
    } else {
        if (!string.IsNullOrEmpty(Game.Intro)) {
            <Paragraph>
                <b>Intro:</b> <GameMessageSpan Text="@Game.Intro"/>
            </Paragraph>
        }
        if (Game.RoundCount.HasValue) {
            <Paragraph>
                <b>Rounds to play:</b> @Game.RoundCount
            </Paragraph>
        }
    }
    <Paragraph Margin="Margin.Is3.OnY">
        <Switch TValue="bool" Value="@(_isPublicOverride ?? Game.IsPublic)" Disabled="@(!IsOwner)"
                ValueChanged="_ => ChangeIsPublic()">
            Anyone can join
        </Switch>
    </Paragraph>
</Container>

<Paragraph>
    @if (IsOwner) {
        <Button Color="Color.Primary" @onclick="_ => Start()">Start the game</Button>
    } else if (!IsParticipant) {
        <Button Color="Color.Primary" @onclick="_ => Join()">Join the game</Button>
    } else {
        <Button Color="Color.Warning" @onclick="_ => Leave()">Leave this game</Button>
    }
</Paragraph>

@code {
    private bool? _isPublicOverride;
    private ValueEditor<string> Intro { get; set; } = new();
    private ValueEditor<string> RoundCount { get; set; } = new() {
        Validator = e => e.OriginalValue == ""
            ? ""
            : int.TryParse(e.Value, out _) ? "" : "Round count must be an integer.",
    };

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        if (_isPublicOverride == Game.IsPublic)
            _isPublicOverride = null;
        using var _ = Computed.BeginIsolation(); // Otherwise the next call may try to reg. as a dependency!
        var parsedIntro = await MessageParser.Parse(Game.Intro);
        Intro.OriginalValue = parsedIntro.Format(true);
        RoundCount.OriginalValue = Game.RoundCount?.ToString() ?? "";
    }

    private Task Start()
        => UICommander.Run(new Game_Start(Session, Game.Id));

    private Task Join()
        => UICommander.Run(new Game_Join(Session, Game.Id));

    private Task Leave()
        => UICommander.Run(new Game_Join(Session, Game.Id, false));

    private Task ChangeIsPublic()
    {
        // Show the new state right away and hold it until the invalidated Game catches up -
        // otherwise Blazor's post-event render repaints the still-stale value, so the switch
        // visibly flips back before the command's invalidation arrives.
        _isPublicOverride = !Game.IsPublic;
        return UICommander.Run(new Game_Edit(Session, Game.Id, _isPublicOverride));
    }

    private Task Edit()
    {
        if (!RoundCount.IsValid)
            return Task.CompletedTask;
        var roundCount = RoundCount.Value != "" ? (int?) int.Parse(RoundCount.Value) : null;
        var command = new Game_Edit(Session, Game.Id,
            Intro: Intro.Value,
            RoundCount: roundCount);
        return UICommander.Run(command);
    }
}
