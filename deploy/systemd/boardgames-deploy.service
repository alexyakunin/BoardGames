[Unit]
Description=BoardGames poll-based auto-deploy
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Environment=REPO_DIR=/opt/apps/boardgames
Environment=BRANCH=main
# Invoke via bash so it runs regardless of the file's executable bit
ExecStart=/bin/bash /opt/apps/boardgames/deploy/deploy.sh
