# Caddy sits behind Cloudflare (proxied / "orange cloud") and terminates TLS
# using a Cloudflare Origin CA certificate. Cloudflare's SSL/TLS mode for the
# host should be Full (strict).
#
# WebSockets (Fusion RPC + Blazor Server) are reverse-proxied transparently.
# The site uses an explicit TLS cert, so Caddy performs no ACME. It still sets
# up the automatic HTTP (:80) -> HTTPS (:443) redirect, which Cloudflare relays.
{$DOMAIN} {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	encode zstd gzip
	reverse_proxy app:8080
}
