# Copy to deploy/.env on the host and fill in real values.
# docker compose reads this file automatically.
#
# Note: TLS + routing now live in the shared edge (ActualLab/DeployConfigs,
# oracle-vm1/edge). This stack no longer runs Caddy, so there is no DOMAIN here.

# PostgreSQL password (used by both the db container and the app connection string)
POSTGRES_PASSWORD=postgres

# OAuth credentials - override the repo's public demo values for a real deployment.
# The OAuth apps must whitelist https://boardgames.actuallab.net/signin-github and /signin-microsoft.
#BOARDGAMES_GITHUBCLIENTID=
#BOARDGAMES_GITHUBCLIENTSECRET=
#BOARDGAMES_MICROSOFTCLIENTID=
#BOARDGAMES_MICROSOFTCLIENTSECRET=
